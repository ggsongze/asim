    Example Inverter - Simple,  !- Name
    On 24/7,                 !- Availability Schedule Name
    ,                        !- Zone Name
    0.3,                     !- Radiative Fraction
    0.95;                    !- Inverter Efficiency

  Generator:Photovoltaic,
    Solar collector 1,       !- Name
    Solar collector 1,       !- Surface Name
    PhotovoltaicPerformance:Simple,  !- Photovoltaic Performance Object Type
    PV Constant Efficiency = 0.15,  !- Module Performance Name
    Decoupled,               !- Heat Transfer Integration Mode
    1,                       !- Number of Series Strings in Parallel {dimensionless}
    1;                       !- Number of Modules in Series {dimensionless}

  Generator:Photovoltaic,
    Solar collector 2,       !- Name
    Solar collector 2,       !- Surface Name
    PhotovoltaicPerformance:Simple,  !- Photovoltaic Performance Object Type
